<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level application menu -->
    <menuitem id="menu_fund_root" name="Fund Management"
              web_icon="nn_fund_management,static/description/icon.png"
              sequence="20"/>

    <!-- Dashboard -->
    <menuitem id="menu_fund_dashboard" name="Dashboard"
              parent="menu_fund_root" action="action_dashboard_accounts"
              sequence="5"/>

    <!-- Operations -->
    <menuitem id="menu_fund_operations" name="Operations"
              parent="menu_fund_root" sequence="10"/>
    <menuitem id="menu_incoming_fund" name="Incoming Funds"
              parent="menu_fund_operations" action="action_incoming_fund"
              sequence="10"/>
    <menuitem id="menu_fund_allocation" name="Allocations"
              parent="menu_fund_operations" action="action_fund_allocation"
              sequence="20"/>
    <menuitem id="menu_fund_requisition" name="Requisitions"
              parent="menu_fund_operations" action="action_fund_requisition"
              sequence="30"/>
    <menuitem id="menu_fund_bill" name="Bills"
              parent="menu_fund_operations" action="action_fund_bill"
              sequence="40"/>
    <menuitem id="menu_fund_transfer" name="Transfers"
              parent="menu_fund_operations" action="action_fund_transfer"
              sequence="50"/>

    <!-- Master data -->
    <menuitem id="menu_fund_master" name="Configuration"
              parent="menu_fund_root" sequence="90"
              groups="nn_fund_management.group_fund_admin"/>
    <menuitem id="menu_fund_account" name="Fund Accounts"
              parent="menu_fund_master" action="action_fund_account"
              sequence="10"/>
    <menuitem id="menu_fund_target" name="Projects / Expense Heads"
              parent="menu_fund_master" action="action_fund_target"
              sequence="20"/>
    <menuitem id="menu_approval_rule" name="Approval Rules"
              parent="menu_fund_master" action="action_approval_rule"
              sequence="30"/>

    <!-- Audit -->
    <menuitem id="menu_fund_audit" name="Audit"
              parent="menu_fund_root" sequence="80"
              groups="nn_fund_management.group_fund_finance"/>
    <menuitem id="menu_fund_history" name="Fund History"
              parent="menu_fund_audit" action="action_fund_history"
              sequence="10"/>

</odoo>
