<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_account_tree" model="ir.ui.view">
        <field name="name">nn.fund.account.tree</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree string="Fund Accounts">
                <field name="name"/>
                <field name="account_type"/>
                <field name="total_received" sum="Total Received"/>
                <field name="held_amount" sum="On Hold"/>
                <field name="total_assigned" sum="Assigned"/>
                <field name="available_balance" sum="Available"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. City Bank Main"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="account_type"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Balances (computed - read only)">
                        <group>
                            <field name="total_received"/>
                            <field name="held_amount"/>
                        </group>
                        <group>
                            <field name="total_assigned"/>
                            <field name="available_balance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Incoming Funds">
                            <field name="incoming_fund_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="transaction_reference"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Allocations">
                            <field name="allocation_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="target_id"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
